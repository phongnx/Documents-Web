{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "shared": {
      "kpi": {
        "$token": {
          ".read": true,
          ".write": "auth != null && (data.exists() ? data.child('meta/ownerId').val() === auth.uid : newData.child('meta/ownerId').val() === auth.uid)",
          "meta": {
            ".validate": "newData.child('ownerId').isString() && (!data.child('ownerId').exists() || data.child('ownerId').val() === newData.child('ownerId').val())"
          },
          "entries": {
            ".indexOn": ["date"],
            "$entryId": {
              ".write": "data.parent().parent().child('meta').exists() && !data.parent().parent().child('scores').child($entryId).exists() && data.parent().parent().child('meta/locked').val() !== true",
              ".validate": "newData.hasChildren(['id','date','createdAt','updatedAt']) && newData.child('date').val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) && (!newData.child('start').exists() || newData.child('start').val().matches(/^[0-9]{2}:[0-9]{2}$/)) && (!newData.child('end').exists() || newData.child('end').val().matches(/^[0-9]{2}:[0-9]{2}$/)) && (!newData.child('task').exists() || (newData.child('task').isString() && newData.child('task').val().length <= 2000)) && (!newData.child('note').exists() || (newData.child('note').isString() && newData.child('note').val().length <= 2000)) && (!newData.child('selfDelta').exists() || newData.child('selfDelta').isNumber())"
            }
          },
          "scores": {
            "$entryId": {
              ".validate": "newData.hasChildren(['delta','scoredAt']) && newData.child('delta').isNumber() && newData.parent().parent().child('entries').child($entryId).exists()"
            }
          }
        }
      },
      "$type": {
        "$id": {
          ".read": true,
          ".write": "auth != null && (!data.exists() ? newData.child('ownerId').val() === auth.uid : data.child('ownerId').val() === auth.uid)"
        }
      }
    }
  }
}
